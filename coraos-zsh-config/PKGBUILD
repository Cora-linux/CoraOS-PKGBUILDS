# Maintainer: CoraOS <support@coraos.org>
pkgname=coraos-zsh-config
pkgver=1.0.5
pkgrel=1
pkgdesc="CoraOS zsh configuration with Powerlevel10k"
arch=('any')
url="https://coraos.org"
license=('GPL-3.0-only')
depends=(
    'zsh'
    'zsh-autosuggestions'
    'zsh-history-substring-search'
    'eza'
    'fzf'
    'fd'
    'bat'
    'zoxide'
    'git'
)
source=(
    '.zshrc'
    '.p10k.zsh'
    'fast-syntax-highlighting::git+https://github.com/Cora-Linux-Distro/fast-syntax-highlighting.git#commit=REPLACE_WITH_REAL_SHA'
)
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
    install -Dm644 "$srcdir/.zshrc" "$pkgdir/usr/share/coraos/zsh/coraos.zshrc"
    install -Dm644 "$srcdir/.p10k.zsh" "$pkgdir/usr/share/coraos/zsh/.p10k.zsh"

    install -d "$pkgdir/usr/share/coraos/zsh/plugins"
    cp -r "$srcdir/fast-syntax-highlighting" "$pkgdir/usr/share/coraos/zsh/plugins/"
}

# vim: set ft=sh ts=2 sw=2 et:
